{
  "manifest_version": 2,
  "name": "eDART Polska - Autodarts Stats",
  "version": "2.2.0",
  "description": "Automatycznie wysyła wyniki meczów ligowych z Autodarts do eDART Polska",
  "browser_specific_settings": {
    "gecko": {
      "id": "edart-extension@edartpolska.pl",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "notifications",
    "webRequest",
    "alarms",
    "https://api.autodarts.io/*",
    "https://play.autodarts.io/*",
    "https://edartpolska.pl/*",
    "https://www.edartpolska.pl/*",
    "https://*.lovable.app/*",
    "https://uiolhzctnbskdjteufkj.supabase.co/*"
  ],
  "background": {
    "scripts": [
      "config.js",
      "cache.js",
      "playerConfig.js",
      "notifications.js",
      "api.js",
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": ["https://play.autodarts.io/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://edartpolska.pl/*",
        "https://www.edartpolska.pl/*",
        "https://*.lovable.app/*",
        "https://*.lovableproject.com/*"
      ],
      "js": ["inject-token.js"],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "icon48.png"
  }
}
