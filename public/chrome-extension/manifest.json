{
  "manifest_version": 3,
  "name": "eDART Polska - Autodarts Stats",
  "version": "2.2.0",
  "description": "Automatycznie wysyła wyniki meczów ligowych z Autodarts do eDART Polska",
  "permissions": ["storage", "notifications", "webRequest", "alarms"],
  "host_permissions": [
    "https://api.autodarts.io/*",
    "https://play.autodarts.io/*",
    "https://edartpolska.pl/*",
    "https://www.edartpolska.pl/*",
    "https://*.lovable.app/*",
    "https://uiolhzctnbskdjteufkj.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://play.autodarts.io/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://edartpolska.pl/*",
        "https://www.edartpolska.pl/*",
        "https://*.lovable.app/*",
        "https://*.lovableproject.com/*"
      ],
      "js": ["inject-token.js"],
      "run_at": "document_start"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon48.png"
  }
}
