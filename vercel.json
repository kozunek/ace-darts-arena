{
  "rewrites": [
    { "source": "/((?!api|assets|pwa-|favicon|robots|manifest|chrome-extension|firefox-extension|eDART_Polska).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
